{
  "system_mode": "multi_camera",
  "database": {
    "host": "localhost",
    "port": 3306,
    "user": "root",
    "password": "YOUR_DATABASE_PASSWORD_HERE",
    "database": "anpr_system",
    "pool_size": 5
  },
  "global_settings": {
    "fps_limit": 30,
    "frame_skip": 2,
    "csv_file": "plate_detections.csv",
    "allowed_plates": "allowed_plates.json",
    "save_dir": "./detected_plates"
  },
  "display_settings": {
    "headless_mode": false,
    "show_fps": true,
    "show_plate_count": true,
    "show_verification_stats": true,
    "window_title": "Multi-Camera ANPR System",
    "grid_layout": "2x2",
    "show_camera_names": true
  },
  "headless_settings": {
    "enabled": false,
    "log_level": "INFO",
    "save_frames": false,
    "frame_save_interval": 30,
    "log_file": "anpr_headless.log",
    "status_update_interval": 10
  },
  "cameras": [
    {
      "id": "Cam_001",
      "name": "ANPR Entrance",
      "location": "Main Gate",
      "rtsp_source": "rtsp://username:password@your_camera_ip:port/stream_path",
      "dedup_window": 50,
      "confidence_threshold": 0.8,
      "enabled": true,
      "api_enabled": false,
      "api_settings": {
        "base_url": "http://your_relay_api_ip/cgi-bin/configManager.cgi",
        "username": "admin",
        "password": "password123",
        "modes": [
          1,
          2
        ],
        "timeout": 5,
        "max_retries": 3
      },
      "roi_polygon": [
        {
          "x": 100,
          "y": 100
        },
        {
          "x": 500,
          "y": 100
        },
        {
          "x": 500,
          "y": 500
        },
        {
          "x": 100,
          "y": 500
        }
      ]
    },
    {
      "id": "Webcam_001",
      "name": "Local Webcam",
      "location": "Office PC",
      "rtsp_source": "0",
      "dedup_window": 30,
      "confidence_threshold": 0.75,
      "enabled": true,
      "api_enabled": false,
      "api_settings": {
        "base_url": "",
        "username": "admin",
        "password": "password123",
        "modes": [
          1,
          2
        ],
        "timeout": 5,
        "max_retries": 3
      },
      "roi": {
        "x1": 10,
        "y1": 10,
        "x2": 600,
        "y2": 450
      }
    }
  ]
}
